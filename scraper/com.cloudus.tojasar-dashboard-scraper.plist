<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.cloudus.tojasar-dashboard-scraper</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/cloudus/projektek/tojasar-dashboard/scraper/run_daily.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/cloudus/projektek/tojasar-dashboard</string>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>8</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/cloudus/projektek/tojasar-dashboard/data/scraper.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/cloudus/projektek/tojasar-dashboard/data/scraper.err.log</string>
</dict>
</plist>
